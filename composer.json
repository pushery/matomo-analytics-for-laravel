{
    "name": "pushery/matomo-analytics-for-laravel",
    "description": "Privacy-first Matomo analytics for Laravel with cookieless tracking, reports, Web Vitals, batching and bot filtering.",
    "keywords": [
        "laravel",
        "matomo",
        "analytics",
        "tracking",
        "privacy",
        "gdpr",
        "piwik",
        "web-analytics",
        "cookieless",
        "web-vitals",
        "reporting-api",
        "bot-detection"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/pushery/matomo-analytics-for-laravel",
    "support": {
        "issues": "https://github.com/pushery/matomo-analytics-for-laravel/issues",
        "source": "https://github.com/pushery/matomo-analytics-for-laravel"
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "illuminate/bus": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/queue": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "matomo/device-detector": "^6.4",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.0",
        "spaze/phpstan-disallowed-calls": "^4.12"
    },
    "suggest": {
        "matomo/matomo-php-tracker": "Use the official server-side Matomo tracker instead of the bundled thin HTTP client",
        "matomo/device-detector": "Exhaustive, upstream-maintained bot detection across every category — wire DeviceDetectorBotDetector through the bots.detector config hook."
    },
    "autoload": {
        "psr-4": {
            "MatomoAnalytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MatomoAnalytics\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=100",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:browser": "pest tests/Browser",
        "test:integration": "pest tests/Integration",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:test": "pint --test",
        "rector": "rector process",
        "rector:test": "rector process --dry-run",
        "mutate": "pest --mutate --everything --covered-only --parallel --min=85",
        "qa": [
            "@format:test",
            "@rector:test",
            "@analyse",
            "@test:type-coverage",
            "@test:coverage"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MatomoAnalytics\\MatomoAnalyticsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
